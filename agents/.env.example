# GovVerify Agent - Truth Engine & Cyber Watchdog
# Environment Variables Configuration
# Copy this file to .env and fill in your values

# ===========================================
# OpenAI Configuration (REQUIRED)
# ===========================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# ===========================================
# WhatsApp Server Configuration
# ===========================================
SERVER_URL=http://localhost:3700
API_KEY=your-api-key-here
CLIENT_PHONE_E164=+1234567890

# ===========================================
# GovVerify Configuration
# ===========================================
GOVVERIFY_NAME=GovVerify
GOVVERIFY_COUNTRY=Sierra Leone

# ===========================================
# Emergency Contacts (Sierra Leone)
# ===========================================
POLICE_CONTACT=+232-999
CYBERCRIME_CONTACT=+232-cybercrime-unit
EMERGENCY_CONTACT=999

# ===========================================
# Data Retention (days)
# ===========================================
RETENTION_METADATA_DAYS=365
RETENTION_SENSITIVE_PII_DAYS=30
RETENTION_INCIDENTS_DAYS=730

# ===========================================
# Debugging
# ===========================================
DEBUG=false

# ===========================================
# Server Configuration
# ===========================================
PORT=3700
NODE_ENV=development

# ===========================================
# Trusted Sources (comma-separated)
# ===========================================
# Government domains to prioritize for verification
TRUSTED_GOV_DOMAINS=gov.sl,statehouse.gov.sl,mohs.gov.sl,sierraleonepolice.gov.sl

# Local news agencies
TRUSTED_NEWS_DOMAINS=thesierraleonetelegraph.com,awoko.org,standardtimespress.org

# International organizations
TRUSTED_INTL_DOMAINS=who.int,un.org

# ===========================================
# Escalation Configuration
# ===========================================
# Enable automatic law enforcement notification for critical threats
AUTO_ESCALATE_CRITICAL=true

# Minimum confidence threshold for automatic verification (0-100)
MIN_CONFIDENCE_THRESHOLD=60

# Time window for breaking news verification (hours)
BREAKING_NEWS_WINDOW_HOURS=72

# ===========================================
# Feature Flags
# ===========================================
ENABLE_IMAGE_VERIFICATION=true
ENABLE_AUDIO_TRANSCRIPTION=true
ENABLE_HUMAN_ESCALATION=true
ENABLE_PROTECTION_GUIDANCE=true

# ===========================================
# Integration APIs (Optional)
# ===========================================
# Reverse image search API
REVERSE_IMAGE_API_KEY=
REVERSE_IMAGE_API_URL=

# Audio transcription API (e.g., Whisper, Google STT)
TRANSCRIPTION_API_KEY=
TRANSCRIPTION_API_URL=

# Fact-checking database API
FACTCHECK_API_KEY=
FACTCHECK_API_URL=

# Government verification API
GOV_VERIFY_API_KEY=
GOV_VERIFY_API_URL=
